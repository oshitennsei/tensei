{
  "manifest_version": 3,
  "name": "Tensei | キャラクターが転生してきた件",
  "version": "0.2.1",
  "description": "Tensei — 好きな小説のキャラクターと対話できる拡張機能",
  "minimum_chrome_version": "114",
  "permissions": ["sidePanel", "storage", "windows", "scripting", "tabs"],
  "host_permissions": [
    "https://kakuyomu.jp/*",
    "https://ncode.syosetu.com/*",
    "https://novel18.syosetu.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "キャラクターが転生してきた件",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidebar/index.html"
  },
  "externally_connectable": {
    "matches": [
      "https://tensei-portal.pages.dev/*",
      "https://tensei.alexlee.ccwu.cc/*"
    ]
  },
  "content_scripts": [
    {
      "js": ["src/content/index.ts"],
      "matches": [
        "https://kakuyomu.jp/*",
        "https://ncode.syosetu.com/*",
        "https://novel18.syosetu.com/*",
        "https://tensei-portal.pages.dev/*",
        "https://tensei.alexlee.ccwu.cc/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
